IPC USING PIPES
# include <stdio.h>
# include <unistd.h>
# include <string.h>
# include <stdlib.h>

int main()
{
    int fd[2];
    pid_t pid;

    char message[] = "Hello from parent!";
    char buffer[100];

    if (pipe(fd) == -1) {
        perror("pipe failed");
        exit(1);
    }

    pid = fork();

    if (pid < 0) {
        perror("fork failed");
        exit(1);
    }

    if (pid == 0) {
        close(fd[1]);
        read(fd[0], buffer, size of (buffer));
        printf("child received message : %s\n", buffer);
        close(fd[0]);
    }
    else {
        close(fd[0]);
        write(fd[1], message, strlen(message) + 1);
        close(fd[1]);
    }

    return 0;
}
OUTPUT

child recived message : Hello from parent
