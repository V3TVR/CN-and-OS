# include <stdio.h>
# include <stdlib.h>

int main()
{
    int frame = 0;
    int ack;
    int total_frames;

    printf(" Enter total no.of frames to send:");
    scanf("%d", &total_frames);

    while (frame < total_frames)
    {
        printf("\nSender : sending frame %d\n", frame);

        printf(" Receiver : Enter ACK for frame %d (1 = ACK, 0 = LOST)", frame);

        scanf("%d", &ack);

        if (ack == 1)
        {
            printf("Sender : ACK received for frame %d\n", frame);
            frame++;
        }
        else
        {
            printf("Sender : ACK lost! Retransmitting frame %d\n", frame);
        }
    }

    printf("\n All frames sent successfully using stop - and wait protocol\n");

    return 0;
}


