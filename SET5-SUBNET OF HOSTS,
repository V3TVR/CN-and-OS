#include <stdio.h>

int a[10][10], n;

void adj(int k)
{
    int i, j;

    printf("Adjacent nodes of root node %d are:\n", k);

    /* Print adjacent nodes */
    for(j = 1; j <= n; j++)
    {
        if(a[k][j] == 1 || a[j][k] == 1)
        {
            printf("%d\t", j);
        }
    }

    printf("\n");

    /* Print non-adjacent nodes */
    printf("Non adjacent nodes are:\n");
    for(j = 1; j <= n; j++)
    {
        if((a[k][j] == 0 && a[j][k] == 0) && (k != j))
        {
            printf("%d\t", j);
        }
    }
}

int main()
{
    int i, j, root;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("Enter the adjacency matrix:\n");
    for(i = 1; i <= n; i++)
    {
        for(j = 1; j <= n; j++)
        {
            scanf("%d", &a[i][j]);
        }
    }

    printf("Enter root node: ");
    scanf("%d", &root);

    adj(root);

    return 0;
}








